# ═══════════════════════════════════════════════════════════════════════════════
# GLOBEX SKY — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════

# MODE: "test" or "live" — controls which API keys are used
APP_MODE=test

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
FRONTEND_URL_WWW=https://www.globexsky.com

# ─── Supabase (TEST) ─────────────────────────────────────────────────────────
TEST_SUPABASE_URL=https://your-test-project.supabase.co
TEST_SUPABASE_ANON_KEY=your-test-anon-key
TEST_SUPABASE_SERVICE_KEY=your-test-service-key

# ─── Supabase (LIVE) ─────────────────────────────────────────────────────────
LIVE_SUPABASE_URL=https://your-live-project.supabase.co
LIVE_SUPABASE_ANON_KEY=your-live-anon-key
LIVE_SUPABASE_SERVICE_KEY=your-live-service-key

# ─── Legacy Supabase (kept for database migration scripts) ────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_JWT_SECRET=your-jwt-secret

# ─── Stripe (TEST) ───────────────────────────────────────────────────────────
TEST_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
TEST_STRIPE_SECRET_KEY=sk_test_xxx
TEST_STRIPE_WEBHOOK_SECRET=whsec_test_xxx

# ─── Stripe (LIVE) ───────────────────────────────────────────────────────────
LIVE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
LIVE_STRIPE_SECRET_KEY=sk_live_xxx
LIVE_STRIPE_WEBHOOK_SECRET=whsec_live_xxx

# ─── OpenAI ──────────────────────────────────────────────────────────────────
TEST_OPENAI_API_KEY=sk-test-xxx
LIVE_OPENAI_API_KEY=sk-xxx

# ─── Agora (Video/Livestream) ────────────────────────────────────────────────
TEST_AGORA_APP_ID=test-app-id
TEST_AGORA_APP_CERTIFICATE=test-cert
LIVE_AGORA_APP_ID=live-app-id
LIVE_AGORA_APP_CERTIFICATE=live-cert

# ─── SMTP ────────────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
EMAIL_FROM=info@globexsky.com

# ─── bKash/Nagad ─────────────────────────────────────────────────────────────
TEST_BKASH_APP_KEY=test-bkash-key
TEST_BKASH_APP_SECRET=test-bkash-secret
LIVE_BKASH_APP_KEY=live-bkash-key
LIVE_BKASH_APP_SECRET=live-bkash-secret

# ─── JWT ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your-jwt-secret-min-32-chars
JWT_REFRESH_SECRET=your-refresh-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Cloudinary ──────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── PayPal (Alternative Payment) ─────────────────────────────────────────────
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_MODE=live

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE=+1your-twilio-phone-number

# ─── Currency API ─────────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate with: node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
VAPID_EMAIL=admin@globexsky.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# ─── Social Authentication (Google & Facebook OAuth) ─────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# ─── Company Info ─────────────────────────────────────────────────────────────
COMPANY_NAME=Globex International Trade Co., Ltd.
COMPANY_NAME_CN=广州戈洛贝克斯凯国际贸易有限公司
COMPANY_PHONE=+8613086766947
COMPANY_EMAIL=info@globexsky.com
