# ═══════════════════════════════════════════════════════════════════════════════
# Globex Sky — Environment Configuration
# Copy this file to .env and fill in all values.
# ═══════════════════════════════════════════════════════════════════════════════

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── API Mode: "test" uses TEST keys, "live" uses LIVE keys ──────────────────
# Set to "live" only when ready for real transactions.
MODE=test

# ─── Supabase Credentials ─────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # SECRET — never expose
SUPABASE_ANON_KEY=your-anon-key                   # Public — safe to expose
SUPABASE_JWT_SECRET=your-jwt-secret               # SECRET — never expose

# ─── Cloudinary (Media Storage) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your-cloud-name             # Public — safe to expose
CLOUDINARY_API_KEY=your-api-key                   # SECRET — never expose
CLOUDINARY_API_SECRET=your-api-secret             # SECRET — never expose

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password                       # SECRET — never expose
EMAIL_FROM=info@globexsky.com

# ─── Frontend URL (for CORS) ──────────────────────────────────────────────────
FRONTEND_URL=https://globexsky.com
FRONTEND_URL_WWW=https://www.globexsky.com

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=your-very-long-random-jwt-secret-here  # SECRET — never expose
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-very-long-refresh-secret  # SECRET — never expose
JWT_REFRESH_EXPIRES_IN=30d

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ─── Admin Panel Settings Encryption ─────────────────────────────────────────
# Used to AES-256-CBC encrypt sensitive API keys stored in the platform_settings DB table.
# Generate a strong random value: node -e "require('crypto').randomBytes(32).toString('hex')"
SETTINGS_ENCRYPTION_KEY=your-32-char-or-longer-encryption-key-here  # SECRET — never expose

# ─── Stripe (Payment Processing) ──────────────────────────────────────────────
# TEST keys (use when MODE=test) — from https://dashboard.stripe.com/test/apikeys
STRIPE_TEST_SECRET_KEY=sk_test_your-stripe-test-secret-key    # SECRET
STRIPE_TEST_PUBLISHABLE_KEY=pk_test_your-stripe-test-publishable-key
STRIPE_TEST_WEBHOOK_SECRET=whsec_your-stripe-test-webhook-secret  # SECRET

# LIVE keys (use when MODE=live) — from https://dashboard.stripe.com/apikeys
STRIPE_LIVE_SECRET_KEY=sk_live_your-stripe-live-secret-key    # SECRET
STRIPE_LIVE_PUBLISHABLE_KEY=pk_live_your-stripe-live-publishable-key
STRIPE_LIVE_WEBHOOK_SECRET=whsec_your-stripe-live-webhook-secret  # SECRET

# ─── PayPal (Alternative Payment) ─────────────────────────────────────────────
# TEST — from https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_TEST_CLIENT_ID=your-paypal-sandbox-client-id
PAYPAL_TEST_CLIENT_SECRET=your-paypal-sandbox-client-secret   # SECRET

# LIVE — from https://developer.paypal.com/dashboard/applications/live
PAYPAL_LIVE_CLIENT_ID=your-paypal-live-client-id
PAYPAL_LIVE_CLIENT_SECRET=your-paypal-live-client-secret      # SECRET

# ─── bKash (Bangladesh Mobile Payment) ────────────────────────────────────────
# TEST — from bKash developer sandbox
BKASH_TEST_APP_KEY=your-bkash-test-app-key
BKASH_TEST_APP_SECRET=your-bkash-test-app-secret              # SECRET
BKASH_TEST_USERNAME=your-bkash-test-username
BKASH_TEST_PASSWORD=your-bkash-test-password                  # SECRET
BKASH_TEST_BASE_URL=https://tokenized.sandbox.bka.sh/v1.2.0-beta

# LIVE — from bKash merchant portal
BKASH_LIVE_APP_KEY=your-bkash-live-app-key
BKASH_LIVE_APP_SECRET=your-bkash-live-app-secret              # SECRET
BKASH_LIVE_USERNAME=your-bkash-live-username
BKASH_LIVE_PASSWORD=your-bkash-live-password                  # SECRET
BKASH_LIVE_BASE_URL=https://tokenized.pay.bka.sh/v1.2.0-beta

# ─── Nagad (Bangladesh Mobile Payment) ────────────────────────────────────────
# TEST — from Nagad developer sandbox
NAGAD_TEST_MERCHANT_ID=your-nagad-test-merchant-id
NAGAD_TEST_PUBLIC_KEY=your-nagad-test-public-key
NAGAD_TEST_PRIVATE_KEY=your-nagad-test-private-key            # SECRET
NAGAD_TEST_BASE_URL=http://sandbox.mynagad.com:10080/remote-payment-gateway-1.0

# LIVE — from Nagad merchant portal
NAGAD_LIVE_MERCHANT_ID=your-nagad-live-merchant-id
NAGAD_LIVE_PUBLIC_KEY=your-nagad-live-public-key
NAGAD_LIVE_PRIVATE_KEY=your-nagad-live-private-key            # SECRET
NAGAD_LIVE_BASE_URL=https://api.mynagad.com/api/dfs

# ─── OpenAI API ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key                         # SECRET — never expose

# ─── Agora (Live Streaming / Video) ───────────────────────────────────────────
AGORA_APP_ID=your-agora-app-id                                # Public — safe to expose
AGORA_APP_CERTIFICATE=your-agora-app-certificate              # SECRET — never expose

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token                      # SECRET — never expose
TWILIO_PHONE=+1your-twilio-phone-number

# ─── Currency API ─────────────────────────────────────────────────────────────
EXCHANGE_RATE_API_KEY=your-exchangerate-api-key               # SECRET — never expose

# ─── Web Push / VAPID ─────────────────────────────────────────────────────────
# Generate with: node -e "const wp=require('web-push');console.log(wp.generateVAPIDKeys())"
VAPID_EMAIL=admin@globexsky.com
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key                      # SECRET — never expose

# ─── Social Authentication (Google & Facebook OAuth) ──────────────────────────
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret                # SECRET — never expose
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret                  # SECRET — never expose

# ─── Company Information ──────────────────────────────────────────────────────
COMPANY_NAME=Globex International Trade Co., Ltd.
COMPANY_NAME_CN=广州戈洛贝克斯凯国际贸易有限公司
COMPANY_PHONE=+8613086766947
COMPANY_EMAIL=info@globexsky.com

# ─── DHL Shipping ─────────────────────────────────────────────────────────────
DHL_API_KEY=your-dhl-api-key                          # SECRET — never expose
DHL_API_SECRET=your-dhl-api-secret                    # SECRET — never expose
DHL_ACCOUNT_NUMBER=your-dhl-account-number
DHL_BASE_URL=https://api-mock.dhl.com/mydhlapi         # Use https://api.dhl.com for production
DHL_WEBHOOK_TOKEN=your-dhl-webhook-token              # SECRET — never expose

# ─── FedEx Shipping ───────────────────────────────────────────────────────────
FEDEX_CLIENT_ID=your-fedex-client-id
FEDEX_CLIENT_SECRET=your-fedex-client-secret          # SECRET — never expose
FEDEX_ACCOUNT_NUMBER=your-fedex-account-number
FEDEX_BASE_URL=https://apis-sandbox.fedex.com          # Use https://apis.fedex.com for production
FEDEX_WEBHOOK_SECRET=your-fedex-webhook-secret        # SECRET — never expose
