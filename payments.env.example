# ─── Stripe ───────────────────────────────────────────────────────────────────
# Stripe secret key (starts with sk_live_ in production, sk_test_ in sandbox)
STRIPE_SECRET_KEY=sk_test_...

# Stripe publishable key (starts with pk_live_ in production, pk_test_ in sandbox)
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Stripe webhook endpoint secret (whsec_...) — from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Connect webhook secret (for supplier payout events)
STRIPE_CONNECT_WEBHOOK_SECRET=whsec_...

# Default currency for Stripe charges (ISO 4217 lowercase)
STRIPE_DEFAULT_CURRENCY=usd

# ─── PayPal ───────────────────────────────────────────────────────────────────
# PayPal REST API client ID
PAYPAL_CLIENT_ID=

# PayPal REST API client secret
PAYPAL_CLIENT_SECRET=

# PayPal webhook ID — from PayPal Developer Dashboard > Webhooks
PAYPAL_WEBHOOK_ID=

# PayPal environment: 'sandbox' or 'live'
PAYPAL_MODE=sandbox

# ─── bKash ────────────────────────────────────────────────────────────────────
# bKash Tokenized Checkout API credentials
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=

# bKash environment: 'sandbox' or 'live'
BKASH_MODE=sandbox

# Callback URL — where bKash redirects after the user authenticates
# Default: {FRONTEND_URL}/pages/payment/payment.html
BKASH_CALLBACK_URL=

# ─── Nagad ────────────────────────────────────────────────────────────────────
# Nagad merchant ID
NAGAD_MERCHANT_ID=

# Nagad merchant mobile number
NAGAD_MERCHANT_MOBILE_NO=

# Nagad's RSA public key (PEM or base64 encoded)
NAGAD_PUBLIC_KEY=

# Merchant's RSA private key (PEM or base64 encoded)
NAGAD_MERCHANT_PRIVATE_KEY=

# Nagad environment: 'sandbox' or 'live'
NAGAD_MODE=sandbox

# Callback URL — where Nagad redirects after the user pays
# Default: {FRONTEND_URL}/pages/payment/payment.html
NAGAD_CALLBACK_URL=

# ─── General / Shared ─────────────────────────────────────────────────────────
# Public URL of the frontend application (used to build redirect / callback URLs)
FRONTEND_URL=https://globexsky.com
